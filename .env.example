# Server
HOST=0.0.0.0
PORT=8080
GRPC_PORT=50051

# Persistence — "memory" requires no database; "postgres" requires DATABASE_URL
ADAPTER=memory

# PostgreSQL (required when ADAPTER=postgres)
DATABASE_URL=postgres://user:password@localhost:5432/boilerplate?sslmode=disable

# Redis (refresh token storage)
REDIS_URL=redis://localhost:6379

# Authentication — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-value-minimum-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Security — comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Observability
OTLP_ENDPOINT=localhost:4317
