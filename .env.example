# Server
HOST=0.0.0.0
PORT=8080
GRPC_PORT=50051

# Persistence — "memory" requires no database; "postgres" requires DATABASE_URL
ADAPTER=memory

# PostgreSQL (required when ADAPTER=postgres)
DATABASE_URL=postgres://user:password@localhost:5432/boilerplate?sslmode=disable

# Redis (refresh token storage)
REDIS_URL=redis://localhost:6379

# PostgreSQL connection pool (used when ADAPTER=postgres)
DB_POOL_MAX_CONNS=10
DB_POOL_MIN_CONNS=2
DB_POOL_CONNECT_TIMEOUT=30s
DB_POOL_IDLE_TIMEOUT=10m
DB_POOL_MAX_LIFETIME=30m

# Redis connection/command timeouts
REDIS_CONNECT_TIMEOUT=2s
REDIS_COMMAND_TIMEOUT=2s

# Authentication — JWT signed with EdDSA (Ed25519). Generate a key pair with:
#   openssl genpkey -algorithm ed25519 -out jwt_private.pem
#   openssl pkey -in jwt_private.pem -pubout -out jwt_public.pem
JWT_PRIVATE_KEY_PATH=./jwt_private.pem
JWT_PUBLIC_KEY_PATH=./jwt_public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Security — comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Observability
OTLP_ENDPOINT=localhost:4317
