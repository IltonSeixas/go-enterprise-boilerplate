# Server
HOST=0.0.0.0
PORT=3000
GRPC_PORT=50051

# Persistence — "memory" requires no database; "postgres" requires DATABASE_URL
ADAPTER=memory

# PostgreSQL (required when ADAPTER=postgres)
DATABASE_URL=postgres://user:password@localhost:5432/boilerplate?sslmode=disable
DATABASE_MAX_CONNS=10
DATABASE_MIN_CONNS=2
DATABASE_CONN_TIMEOUT=30s

# Redis (required when ADAPTER=postgres)
REDIS_URL=redis://localhost:6379

# Authentication — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-value-minimum-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4321
RATE_LIMIT_RPS=100
RATE_LIMIT_WINDOW=60s

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=go-enterprise-boilerplate
OTEL_SERVICE_VERSION=0.1.0
